          "name": "01 Search Flights \u2014 200 Happy Path",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response is an array', () => pm.expect(pm.response.json()).to.be.an('array'));",
                  "pm.test('Each flight has required fields', () => {",
                  "    pm.response.json().forEach(f => {",
                  "        pm.expect(f).to.have.all.keys('flightId','flightNumber','departureAirport','arrivalAirport','departureTime','availableSeats');",
                  "    });",
                  "});",
                  "const flights = pm.response.json();",
                  "if (flights.length > 0) {",
                  "    pm.collectionVariables.set('flightNumber', flights[0].flightNumber);",
                  "    console.log('Saved flightNumber:', flights[0].flightNumber);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/flights/search?departureAirport=BCN&arrivalAirport=ATL&date=2026-04-08T00:00:00Z",
