        {
          "name": "04 Get Reservation \u2014 200 Happy Path (status: Pending)",
          "event": [
            {
              "listen": "pre-request",
              "script": {
                "exec": [
                  "// Relies on 03 having set pm.environment(\"reservationId\").",
                  "// If reservationId is missing, 03 Create did not run or failed \u2014 check 03 first.",
                  "const id = pm.environment.get(\"reservationId\") || pm.collectionVariables.get(\"reservationId\");",
                  "if (!id) {",
                  "    console.error(\"04 pre-request: reservationId not set. Run 03 Create first.\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response has reservation fields', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('reservationId');",
                  "    pm.expect(body).to.have.property('status');",
                  "    pm.expect(body).to.have.property('flightNumber');",
