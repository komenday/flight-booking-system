    {
      "name": "Reservations",
      "item": [
        {
          "name": "00 Reservation Suite Setup \u2014 Get Available Seat",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// This runs SYNCHRONOUSLY after the response.",
                  "// Sets seatNumber in environment so 03 Create can use {{seatNumber}}.",
                  "// Must run before 03 Create Reservation.",
                  "const seats = pm.response.json().seats || [];",
                  "const available = seats.find(function(s) { return s.isAvailable; });",
                  "if (available) {",
                  "    pm.environment.set(\"seatNumber\", available.seatNumber);",
                  "    console.log(\"Setup: available seat found:\", available.seatNumber);",
                  "} else {",
                  "    console.error(\"Setup: no available seats on flight \u2014 cannot run 03-07 tests\");",
                  "}",
                  "pm.test(\"Flight has available seats for reservation tests\",",
                  "    () => pm.expect(available).to.not.be.undefined);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/flights/{{flightNumber}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "flights",
                "{{flightNumber}}"
              ],
              "query": []
            },
            "description": "Setup step: fetches flight seat map synchronously. Test script sets seatNumber in environment for use in 03 Create Reservation. Must be the first request in the Reservations folder."
          }
        },
        {
          "name": "03 Create Reservation \u2014 201 Happy Path",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Response has reservationId', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('reservationId');",
                  "    pm.expect(body.reservationId).to.be.a('string').and.not.empty;",
                  "});",
                  "const reservationId = pm.response.json().reservationId;",
                  "// Write to environment (not just collectionVariables) so {{reservationId}}",
                  "// in subsequent request URLs resolves correctly (environment takes priority).",
                  "pm.environment.set('reservationId', reservationId);",
                  "pm.collectionVariables.set('reservationId', reservationId);",
                  "console.log('Saved reservationId:', reservationId);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
