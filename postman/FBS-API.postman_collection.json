          "name": "02 Get Flight By Number \u2014 200 Happy Path",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response has flight details with seats', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.all.keys('flightId','flightNumber','departureAirport','arrivalAirport','departureTime','totalSeats','availableSeats','seats');",
                  "    pm.expect(body.seats).to.be.an('array').and.not.empty;",
                  "});",
                  "pm.test('Each seat has seatNumber and isAvailable', () => {",
                  "    pm.response.json().seats.forEach(s => {",
                  "        pm.expect(s).to.have.property('seatNumber');",
                  "        pm.expect(s).to.have.property('isAvailable');",
                  "    });",
                  "});",
                  "const availableSeat = pm.response.json().seats.find(s => s.isAvailable);",
                  "if (availableSeat) {",
                  "    pm.collectionVariables.set('seatNumber', availableSeat.seatNumber);",
                  "    console.log('Saved seatNumber:', availableSeat.seatNumber);",
                  "}"
                ],
